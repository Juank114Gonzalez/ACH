# ============================================================
# ACH Finance – Root Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ach_finance
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
JWT_ACCESS_SECRET=change_me_to_at_least_32_random_chars_A
JWT_REFRESH_SECRET=change_me_to_at_least_32_random_chars_B
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
