NODE_ENV=development
PORT=4000

# Neon / PostgreSQL
# Use the DIRECT (non-pooler) connection string for migrations and the API server.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/ach_finance

# JWT — use long random strings (min 32 chars) in production
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-string-at-least
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
# Comma-separated origins (Vercel URL + localhost for testing)
CORS_ORIGIN=http://localhost:3000
# Leave empty when frontend and API are on different domains (Vercel + Render)
COOKIE_DOMAIN=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
